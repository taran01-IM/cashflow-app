# Copy to .env.local and fill in values for local development.
# Production values live in Vercel → Project Settings → Environment Variables.

# Neon Postgres connection string (from console.neon.tech)
DATABASE_URL="postgresql://USER:PASS@ep-xxxxxx.region.aws.neon.tech/neondb?sslmode=require"

# Random secret for JWT signing — generate: `openssl rand -hex 32`
JWT_SECRET="change-me-to-a-long-random-string"

# Token required by /api/admin/seed — pick anything, only you call this endpoint
SEED_TOKEN="change-me-to-a-random-string"
